<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Başlık -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VibiShaver"
        android:textColor="@color/white"
        android:textSize="32sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sanal Tıraş Makinesi"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Güç göstergesi -->
    <TextView
        android:id="@+id/tvPowerNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3"
        android:textColor="@color/accent_blue"
        android:textSize="72sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp" />

    <TextView
        android:id="@+id/tvPowerLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Orta"
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/tvPowerNumber"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- SeekBar güç seçici -->
    <SeekBar
        android:id="@+id/seekBarPower"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:progressTint="@color/accent_blue"
        android:thumbTint="@color/accent_blue"
        app:layout_constraintTop_toBottomOf="@id/tvPowerLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginStart="32dp"
        app:layout_constraintTop_toBottomOf="@id/seekBarPower"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="5"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginEnd="32dp"
        app:layout_constraintTop_toBottomOf="@id/seekBarPower"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Ana buton - tıraş makinesi ikonu -->
    <ImageView
        android:id="@+id/btnShaver"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:src="@drawable/ic_shaver"
        android:alpha="0.6"
        android:padding="16dp"
        android:background="@drawable/btn_shaver_bg"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toBottomOf="@id/seekBarPower"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kapalı"
        android:textColor="@color/text_secondary"
        android:textSize="18sp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/btnShaver"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Başlatmak için butona dokun"
        android:textColor="@color/text_hint"
        android:textSize="13sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
